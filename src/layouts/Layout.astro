---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="description" content="Cassidoo's Interview Questions">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="generator" content={Astro.generator}>
    <title>{title}</title>
  </head>
  <body class="min-h-screen font-sans bg-slate-50 text-slate-900">
    <div class="py-8 px-4 mx-auto max-w-3xl">
      <header class="mb-12 text-center">
        <h1 class="mb-2 text-4xl font-bold text-slate-900">
          <a href="/" class="transition-colors hover:text-indigo-600">
            Cassidoo's Interview Questions
          </a>
        </h1>
        <p class="text-slate-600">
          A collection of weekly interview questions from
          <a
            href="https://cassidoo.co/newsletter/"
            class="text-indigo-600 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
            >cassidoo's newsletter</a
          >.
        </p>
      </header>
      <main>
        <slot />
      </main>
      <footer
        class="pt-8 mt-16 text-sm text-center border-t border-slate-200 text-slate-500"
      >
        <p>
          Unofficial archive. All content &copy;
          <a
            href="https://cassidoo.co/"
            class="hover:text-indigo-600"
            target="_blank"
            rel="noopener noreferrer"
            >Cassidy Williams</a
          >.
        </p>
      </footer>
    </div>
  </body>
</html>
