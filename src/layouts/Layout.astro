---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="description" content="Cassidoo's Interview Questions">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="generator" content={Astro.generator}>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <h1>
          <a href="/"> Cassidoo's Interview Questions </a>
        </h1>
        <p>
          A collection of weekly interview questions from
          <a
            href="https://cassidoo.co/newsletter/"
            class="newsletter-link"
            target="_blank"
            rel="noopener noreferrer"
            >cassidoo's newsletter</a
          >.
        </p>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          Unofficial archive. All content &copy;
          <a
            href="https://cassidoo.co/"
            target="_blank"
            rel="noopener noreferrer"
            >Cassidy Williams</a
          >.
        </p>
      </footer>
    </div>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    color: #0f172a;
    background: #f8fafc;
  }

  .site-shell {
    max-width: 48rem;
    padding: 2rem 1rem;
    margin: 0 auto;
  }

  .site-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 2.5rem;
  }

  h1 a,
  .site-footer a {
    transition: color 150ms ease;
  }

  h1 a:hover,
  .site-footer a:hover {
    color: #4f46e5;
  }

  .site-header p {
    margin: 0;
    color: #475569;
  }

  .newsletter-link {
    color: #4f46e5;
  }

  .newsletter-link:hover {
    text-decoration: underline;
  }

  .site-footer {
    padding-top: 2rem;
    margin-top: 4rem;
    font-size: 0.875rem;
    color: #64748b;
    text-align: center;
    border-top: 1px solid #e2e8f0;
  }

  .site-footer p {
    margin: 0;
  }
</style>
