---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const questions = await getCollection("questions");
  questions.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return questions.map((question, index) => ({
    params: { slug: question.id },
    props: {
      question,
      prevQuestion: index > 0 ? questions[index - 1] : null,
      nextQuestion: index < questions.length - 1 ? questions[index + 1] : null,
    },
  }));
}

const { question, prevQuestion, nextQuestion } = Astro.props;
const { Content } = await render(question);

const date = new Date(question.data.date).toLocaleDateString("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={`Question #${question.data.number} - Cassidoo's Interview Questions`}
>
  <article class="question-detail">
    <div class="question-body">
      <nav class="question-nav" aria-label="Question navigation">
        <div>
          {prevQuestion && (
                     <a
                        class="button previous-next"
                        href={`/questions/${prevQuestion.id}`}
                     >
                        <Icon class="icon" name="lucide:chevron-left" />
                        <span class="muted-number">
                           #{prevQuestion.data.number}
                        </span>
                     </a>
                  )}
        </div>
        <div>
          <a href="/" class="button all-questions">All questions</a>
        </div>
        <div>
          {nextQuestion && (
                     <a
                        class="button previous-next"
                        href={`/questions/${nextQuestion.id}`}
                     >
                        <span class="muted-number">
                           #{nextQuestion.data.number}
                        </span>
                        <Icon class="icon" name="lucide:chevron-right" />
                     </a>
                  )}
        </div>
      </nav>

      <div class="question-meta">
        <span class="question-badge"> #{question.data.number} </span>
        <time>{date}</time>
      </div>

      <div class="markdown-content">
        <Content />
      </div>

      <footer class="question-links">
        <div>
          <a href="/" class="button back-link">← Back to all questions</a>
          <a
            href={question.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="button all-questions"
          >
            View original newsletter ↗
          </a>
        </div>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .question-detail {
    max-width: none;
    color: var(--card-foreground);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 0.125rem);
    box-shadow: 0 1px 3px rgb(15 23 42 / 0.1);
  }

  .question-body {
    padding: 2rem;
  }

  .question-nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .question-nav > :nth-child(2) {
    justify-self: center;
  }

  .question-nav > :last-child {
    justify-self: end;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    padding: 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    border-radius: calc(var(--radius) - 0.125rem);
    transition:
      color 150ms ease,
      background-color 150ms ease;
  }

  .button:hover {
    color: var(--accent-foreground);
    background: var(--accent);
  }

  .button:focus-visible,
  .question-badge:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .previous-next {
    gap: 0.5rem;
    height: 2.5rem;
    padding: 0 1rem;
  }

  .icon {
    width: 1rem;
    height: 1rem;
  }

  .muted-number {
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .question-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .question-meta time {
    font-size: 0.875rem;
    color: #64748b;
  }

  .question-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #4f46e5;
    background: #eef2ff;
    border-radius: calc(var(--radius) - 0.125rem);
  }

  .question-badge:hover {
    background: #e0e7ff;
  }

  .question-links {
    padding-top: 1.5rem;
    margin-top: 2rem;
    border-top: 1px solid #f1f5f9;
  }

  .question-links > div {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    height: 2.5rem;
    padding: 0 1rem;
    color: var(--primary);
  }

  .back-link:hover {
    text-decoration: underline;
    background: transparent;
  }

  @media (max-width: 36rem) {
    .question-body {
      padding: 1.25rem;
    }

    .previous-next {
      padding: 0 0.5rem;
    }
  }
</style>

<style is:global>
  /* Custom styling for the markdown content to look nice */
  .markdown-content h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
  }
  .markdown-content p {
    margin-bottom: 1rem;
    line-height: 1.625;
    color: #334155;
  }
  .markdown-content pre {
    padding: 1rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    color: #f8fafc;
    background-color: #0f172a;
    border-radius: 0.5rem;
  }
  .markdown-content code {
    padding: 0.125rem 0.375rem;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    color: #db2777;
    background-color: #f1f5f9;
    border-radius: 0.25rem;
  }
  .markdown-content pre code {
    padding: 0;
    font-size: 0.875rem;
    color: inherit;
    background-color: transparent;
  }
  .markdown-content ul {
    margin-bottom: 1rem;
    margin-left: 1.5rem;
    color: #334155;
    list-style-position: outside;
    list-style-type: disc;
  }
  .markdown-content li {
    padding-left: 0.25rem;
  }
  .markdown-content ul > li + li {
    margin-top: 0.25rem;
  }
</style>
