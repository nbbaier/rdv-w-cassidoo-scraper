---
import { Icon } from "astro-icon/components";

interface Question {
  date: string;
  excerpt: string;
  number: number;
  slug: string;
  year: number;
}

interface Props {
  questions: Question[];
  years: number[];
}

const { questions, years } = Astro.props;

// Initial state for server rendering (optional, but good for SEO/Flash of content)
// We'll render the first page server-side.
const initialPageSize = 10;
const initialQuestions = questions.slice(0, initialPageSize);
const totalItems = questions.length;
const showingRange = `0-${Math.min(initialPageSize, totalItems)}`;
---

<div id="questions-app">
  <!-- Search and Year Filter -->
  <div class="filters">
    <div class="search-field">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="search-icon"
      >
        <title>Search</title>
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Search questions..."
        class="control search-input"
      >
    </div>

    <div class="year-filter">
      <div class="custom-select">
        <button type="button" id="year-select-trigger" class="select-trigger">
          <span class="value">All Years</span>
          <Icon name="lucide:chevron-down" class="select-chevron" />
        </button>
        <div
          id="year-select-dropdown"
          class="custom-select-dropdown hidden year-dropdown"
        >
          <div class="options">
            <div class="option-item" data-value="">
              <span class="check-slot">
                <Icon class="check-icon" name="lucide:check" />
              </span>
              All Years
            </div>
            {years.map((year) => (
                        <div class="option-item" data-value={year}>
                           <span class="check-slot">
                              <Icon
                                 class="check-icon opacity-0"
                                 name="lucide:check"
                              />
                           </span>
                           {year}
                        </div>
                     ))}
          </div>
        </div>
        <input type="hidden" id="year-select" value="">
      </div>
    </div>
  </div>

  <!-- Pagination Controls -->
  <div class="pagination">
    <div class="pagination-row">
      <div class="page-size">
        <label for="page-size-select" class="desktop-label"> Show: </label>
        <div class="custom-select page-size-select">
          <button
            type="button"
            id="page-size-trigger"
            class="select-trigger small-trigger"
          >
            <span class="value">10</span>
            <Icon name="lucide:chevron-down" class="select-chevron" />
          </button>
          <div
            id="page-size-dropdown"
            class="custom-select-dropdown hidden size-dropdown"
          >
            <div class="options">
              {[10, 25, 50, 100].map((size) => (
                           <div class="option-item" data-value={size}>
                              <span class="check-slot">
                                 <Icon
                                    class={`check-icon ${size === 10 ? "" : "opacity-0"}`}
                                    name="lucide:check"
                                 />
                              </span>
                              {size}
                           </div>
                        ))}
            </div>
          </div>
          <input type="hidden" id="page-size-select" value="10">
        </div>
        <span class="desktop-label"> per page </span>
      </div>

      <div class="paging-buttons">
        <button id="prev-page-btn" class="page-button" disabled type="button">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="button-icon"
          >
            <title>Previous Page</title>
            <path d="m15 18-6-6 6-6"></path>
          </svg>
        </button>
        <div class="page-count">
          <input
            type="number"
            id="page-input"
            min="1"
            value="1"
            class="control page-input"
          >
          <span class="pagination-text">/</span>
          <span id="total-pages-display" class="pagination-text">
            {Math.ceil(totalItems / initialPageSize)}
          </span>
        </div>
        <button type="button" id="next-page-btn" class="page-button">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="button-icon"
          >
            <title>Next Page</title>
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
      </div>

      <div id="showing-range" class="showing-range">
        {showingRange}
        of {totalItems}
      </div>
    </div>

    <!-- Mobile-only total count -->
    <div id="showing-range-mobile" class="showing-range-mobile">
      {showingRange}
      of {totalItems} questions
    </div>
  </div>

  <!-- Questions List -->
  <div id="questions-list" class="questions-list">
    {initialQuestions.map((question) => (
            <a href={`/questions/${question.slug}`}>
               <div class="question-card">
                  <div class="question-card-body">
                     <div class="question-card-meta">
                        <div class="question-badge">#{question.number}</div>
                        <time>{question.date}</time>
                     </div>
                     <div class="question-excerpt">{question.excerpt}...</div>
                  </div>
               </div>
            </a>
         ))}
  </div>
  <div id="no-results" class="no-results hidden">
    No questions found matching your search.
  </div>
</div>

<script is:inline define:vars={{ questions, initialPageSize }}>
  const allQuestions = questions;
  let filteredQuestions = [...allQuestions];
  let currentPage = 1;
  let pageSize = initialPageSize;
  let searchTerm = "";
  let selectedYear = "";
  let searchIndex =
    /** @type {{ slug: string; date: string; number: number; excerpt: string }[]} */ ([]);

  // DOM Elements
  const searchInput = document.getElementById("search-input");
  const yearSelectInput = document.getElementById("year-select");
  const pageSizeSelectInput = document.getElementById("page-size-select");
  const prevPageBtn = document.getElementById("prev-page-btn");
  const nextPageBtn = document.getElementById("next-page-btn");
  const pageInput = document.getElementById("page-input");
  const totalPagesDisplay = document.getElementById("total-pages-display");
  const showingRangeEl = document.getElementById("showing-range");
  const showingRangeMobileEl = document.getElementById("showing-range-mobile");
  const questionsListEl = document.getElementById("questions-list");
  const noResultsEl = document.getElementById("no-results");

  // Custom Select Logic
  function setupCustomSelect(triggerId, dropdownId, inputId, onSelect) {
    const trigger = document.getElementById(triggerId);
    const dropdown = document.getElementById(dropdownId);
    const input = document.getElementById(inputId);
    const options = dropdown.querySelectorAll(".option-item");

    if (!(trigger && dropdown && input)) {
      return;
    }

    // Toggle Dropdown
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = dropdown.classList.contains("hidden");
      // Close all other dropdowns
      for (const el of document.querySelectorAll(".custom-select-dropdown")) {
        if (el.id !== dropdownId) {
          el.classList.add("hidden");
        }
      }

      if (isHidden) {
        dropdown.classList.remove("hidden");
      } else {
        dropdown.classList.add("hidden");
      }
    });

    // Option Click
    for (const option of options) {
      option.addEventListener("click", (e) => {
        e.stopPropagation();
        const value = option.dataset.value;
        const label = option.textContent.trim();

        // Update Input
        input.value = value;

        // Update Trigger Label
        const valueSpan = trigger.querySelector(".value");
        if (valueSpan) {
          valueSpan.textContent = label;
        }

        // Update Checkmarks
        for (const opt of options) {
          const check = opt.querySelector(".check-icon");
          if (check) {
            if (opt === option) {
              check.classList.remove("opacity-0");
            } else {
              check.classList.add("opacity-0");
            }
          }
        }

        // Close Dropdown
        dropdown.classList.add("hidden");

        // Trigger Callback
        if (onSelect) {
          onSelect(value);
        }
      });
    }

    // Close on Click Outside
    document.addEventListener("click", (e) => {
      if (!(trigger.contains(e.target) || dropdown.contains(e.target))) {
        dropdown.classList.add("hidden");
      }
    });
  }

  // Initialize Custom Selects
  setupCustomSelect(
    "year-select-trigger",
    "year-select-dropdown",
    "year-select",
    (val) => {
      selectedYear = val;
      currentPage = 1;
      filterQuestions();
    }
  );

  setupCustomSelect(
    "page-size-trigger",
    "page-size-dropdown",
    "page-size-select",
    (val) => {
      pageSize = Number.parseInt(val, 10);
      currentPage = 1;
      renderQuestions();
    }
  );

  // Load search index
  fetch("/search.json")
    .then((res) => res.json())
    .then((data) => {
      searchIndex =
        /** @type {{ slug: string; date: string; number: number; excerpt: string }[]} */ (
          data
        );
    })
    .catch((err) => console.error("Failed to load search index", err));

  function renderQuestions() {
    const totalPages = Math.ceil(filteredQuestions.length / pageSize);
    const startIdx = (currentPage - 1) * pageSize;
    const endIdx = Math.min(startIdx + pageSize, filteredQuestions.length);
    const paginatedQuestions = filteredQuestions.slice(startIdx, endIdx);

    // Update Pagination UI
    pageInput.value = currentPage;
    pageInput.max = totalPages;
    totalPagesDisplay.textContent = Math.max(totalPages, 1);

    prevPageBtn.disabled = currentPage === 1;
    nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;

    const rangeText =
      filteredQuestions.length === 0 ? "0-0" : `${startIdx + 1}-${endIdx}`;
    showingRangeEl.textContent = `${rangeText} of ${filteredQuestions.length}`;
    showingRangeMobileEl.textContent = `${rangeText} of ${filteredQuestions.length} questions`;

    // Render Questions
    if (paginatedQuestions.length > 0) {
      questionsListEl.innerHTML = paginatedQuestions
        .map(
          (q) => `
                                                                                                             <a href="/questions/${q.slug}">
                                                                                                               <div class="question-card">
                                                                                                                 <div class="question-card-body">
                                                                                                                   <div class="question-card-meta">
                                                                                                                     <div class="question-badge">
                                                                                                                       #${q.number}
                                                                                                                     </div>
                                                                                                                     <time>${q.date}</time>
                                                                                                                   </div>
                                                                                                                   <div class="question-excerpt">
                                                                                                                     ${q.excerpt}...
                                                                                                                   </div>
                                                                                                                 </div>
                                                                                                               </div>
                                                                                                             </a>
                                                                                                           `
        )
        .join("");
      questionsListEl.classList.remove("hidden");
      noResultsEl.classList.add("hidden");
    } else {
      questionsListEl.innerHTML = "";
      questionsListEl.classList.add("hidden");
      noResultsEl.classList.remove("hidden");
    }
  }

  function filterQuestions() {
    filteredQuestions = allQuestions;

    // Filter by year
    if (selectedYear) {
      filteredQuestions = filteredQuestions.filter(
        (q) => q.year === Number.parseInt(selectedYear, 10)
      );
    }

    // Filter by search term
    if (searchTerm) {
      const term = searchTerm.toLowerCase();
      if (searchIndex.length > 0) {
        const matchingSlugs = new Set();
        for (const item of searchIndex) {
          if (
            item.excerpt.toLowerCase().includes(term) ||
            item.date.includes(term) ||
            String(item.number).includes(term) ||
            item.slug.includes(term)
          ) {
            matchingSlugs.add(item.slug);
          }
        }
        filteredQuestions = filteredQuestions.filter((q) =>
          matchingSlugs.has(q.slug)
        );
      } else {
        // Fallback if search index not loaded yet
        filteredQuestions = filteredQuestions.filter(
          (q) =>
            q.date.includes(term) ||
            String(q.number).includes(term) ||
            q.excerpt.toLowerCase().includes(term)
        );
      }
    }

    // Reset to page 1 if pages reduced
    const totalPages = Math.ceil(filteredQuestions.length / pageSize);
    if (currentPage > totalPages) {
      currentPage = 1;
    } else if (currentPage === 0 && totalPages > 0) {
      currentPage = 1;
    }

    renderQuestions();
  }

  // Event Listeners
  searchInput.addEventListener("input", (e) => {
    searchTerm = e.target.value;
    currentPage = 1;
    filterQuestions();
  });

  prevPageBtn.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage--;
      window.scrollTo({ top: 0, behavior: "smooth" });
      renderQuestions();
    }
  });

  nextPageBtn.addEventListener("click", () => {
    const totalPages = Math.ceil(filteredQuestions.length / pageSize);
    if (currentPage < totalPages) {
      currentPage++;
      window.scrollTo({ top: 0, behavior: "smooth" });
      renderQuestions();
    }
  });

  pageInput.addEventListener("change", (e) => {
    const val = Number.parseInt(e.target.value, 10);
    const totalPages = Math.ceil(filteredQuestions.length / pageSize);
    if (val >= 1 && val <= totalPages) {
      currentPage = val;
      renderQuestions();
    } else {
      e.target.value = currentPage;
    }
  });

  pageInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      pageInput.blur();
    }
  });
</script>

<style is:global>
  #questions-app {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  #questions-app .hidden {
    display: none;
  }

  #questions-app .opacity-0 {
    opacity: 0;
  }

  #questions-app .filters {
    display: flex;
    gap: 0.5rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  #questions-app .search-field,
  #questions-app .custom-select {
    position: relative;
  }

  #questions-app .search-field {
    flex: 1;
  }

  #questions-app .search-icon {
    position: absolute;
    top: 50%;
    left: 0.75rem;
    width: 1rem;
    height: 1rem;
    color: var(--muted-foreground);
    transform: translateY(-50%);
  }

  #questions-app .control {
    width: 100%;
    min-width: 0;
    color: var(--foreground);
    outline: none;
    background: white;
    border: 1px solid var(--input);
    border-radius: calc(var(--radius) - 0.125rem);
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.05);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  #questions-app .control::placeholder {
    color: var(--muted-foreground);
  }

  #questions-app .control:focus-visible,
  #questions-app .select-trigger:focus-visible,
  #questions-app .page-button:focus-visible {
    outline: none;
    border-color: var(--ring);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--ring) 45%, transparent);
  }

  #questions-app .control:disabled,
  #questions-app .select-trigger:disabled,
  #questions-app .page-button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  #questions-app .search-input {
    height: 2.5rem;
    padding: 0.25rem 0.75rem 0.25rem 2.5rem;
    font-size: 0.875rem;
  }

  #questions-app .year-filter {
    position: relative;
    width: 11.25rem;
  }

  #questions-app .select-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 2.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--foreground);
    background: white;
    border: 1px solid var(--input);
    border-radius: calc(var(--radius) - 0.125rem);
  }

  #questions-app .select-chevron,
  #questions-app .check-icon,
  #questions-app .button-icon {
    width: 1rem;
    height: 1rem;
  }

  #questions-app .select-chevron {
    opacity: 0.5;
  }

  #questions-app .custom-select-dropdown {
    position: absolute;
    top: 100%;
    z-index: 50;
    width: 100%;
    min-width: 8rem;
    margin-top: 0.25rem;
    overflow: hidden;
    color: var(--popover-foreground);
    background: var(--popover);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) - 0.125rem);
    box-shadow: 0 4px 6px rgb(15 23 42 / 0.1);
    animation: dropdown-in 120ms ease-out;
  }

  #questions-app .size-dropdown {
    min-width: 4rem;
  }

  #questions-app .options {
    max-height: 18.75rem;
    padding: 0.25rem;
    overflow-y: auto;
  }

  #questions-app .option-item {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.375rem 0.5rem 0.375rem 2rem;
    font-size: 0.875rem;
    cursor: pointer;
    user-select: none;
    outline: none;
    border-radius: 0.125rem;
  }

  #questions-app .option-item:hover,
  #questions-app .option-item:focus {
    color: var(--accent-foreground);
    background: var(--accent);
  }

  #questions-app .check-slot {
    position: absolute;
    left: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 0.875rem;
    height: 0.875rem;
  }

  #questions-app .pagination {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 56rem;
    padding: 1rem;
    margin: 0 auto;
    background: white;
    border: 1px solid #f1f5f9;
    border-radius: calc(var(--radius) - 0.125rem);
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.05);
  }

  #questions-app .pagination-row,
  #questions-app .page-size,
  #questions-app .paging-buttons,
  #questions-app .page-count {
    display: flex;
    align-items: center;
  }

  #questions-app .pagination-row {
    gap: 1rem;
    justify-content: space-between;
  }

  #questions-app .page-size,
  #questions-app .paging-buttons {
    gap: 0.5rem;
  }

  #questions-app .page-count {
    gap: 0.375rem;
  }

  #questions-app .desktop-label,
  #questions-app .pagination-text,
  #questions-app .showing-range {
    font-size: 0.875rem;
    color: #475569;
  }

  #questions-app .page-size-select {
    min-width: 4.375rem;
  }

  #questions-app .small-trigger {
    gap: 0.5rem;
    height: 2.25rem;
  }

  #questions-app .page-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding: 0 0.75rem;
    background: var(--background);
    border: 1px solid var(--input);
    border-radius: calc(var(--radius) - 0.125rem);
    box-shadow: 0 1px 2px rgb(15 23 42 / 0.05);
    transition:
      color 150ms ease,
      background-color 150ms ease;
  }

  #questions-app .page-button:hover:not(:disabled) {
    color: var(--accent-foreground);
    background: var(--accent);
  }

  #questions-app .page-input {
    width: 2.5rem;
    height: 2.25rem;
    padding: 0 0.375rem;
    font-size: 0.875rem;
    text-align: center;
    appearance: textfield;
  }

  #questions-app .page-input::-webkit-outer-spin-button,
  #questions-app .page-input::-webkit-inner-spin-button {
    appearance: none;
  }

  #questions-app .showing-range-mobile {
    display: none;
    font-size: 0.75rem;
    color: #64748b;
    text-align: center;
  }

  #questions-app .questions-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  #questions-app .question-card {
    color: var(--card-foreground);
    cursor: pointer;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 0.125rem);
    box-shadow: 0 1px 3px rgb(15 23 42 / 0.1);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  #questions-app .question-card:hover {
    border-color: #a5b4fc;
    box-shadow: 0 4px 6px rgb(15 23 42 / 0.1);
  }

  #questions-app .question-card-body {
    padding: 1.5rem;
  }

  #questions-app .question-card-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  #questions-app .question-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #4f46e5;
    background: #eef2ff;
    border-radius: calc(var(--radius) - 0.125rem);
    transition: background-color 150ms ease;
  }

  #questions-app .question-badge:hover {
    background: #e0e7ff;
  }

  #questions-app .question-card time {
    font-size: 0.875rem;
    color: #94a3b8;
  }

  #questions-app .question-excerpt {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    -webkit-line-clamp: 2;
    color: #334155;
  }

  #questions-app .question-card:hover .question-excerpt {
    color: #0f172a;
  }

  #questions-app .no-results {
    padding: 3rem 0;
    color: #64748b;
    text-align: center;
  }

  @keyframes dropdown-in {
    from {
      opacity: 0;
      transform: translateY(-0.125rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 39.999rem) {
    #questions-app .desktop-label,
    #questions-app .showing-range {
      display: none;
    }

    #questions-app .showing-range-mobile {
      display: block;
    }
  }
</style>
